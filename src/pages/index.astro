---
---
<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#111111">
  <meta name="description" content="Plein5 Cafetaria & Broodjesbar in Beegden. Bekijk onze menukaart, bel je afhaalbestelling door of kom gezellig bij ons eten.">
  <meta property="og:title" content="Plein5 — Cafetaria & Broodjesbar Beegden">
  <meta property="og:description" content="Bekijk de menukaart van Plein5 in Beegden. Bestellen kan telefonisch of aan de balie.">
  <meta property="og:image" content="/assets/plein5-hero.jpg">
  <title>Plein5 — Cafetaria & Broodjesbar Beegden</title>
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/styles.css?v=13">
</head>
<body>
  <a class="skip-link" href="#main">Direct naar inhoud</a>
  <header class="site-header" id="top">
    <a class="brand" href="#top" aria-label="Plein5 home">
      <span class="brand-word">PLEIN</span><span class="brand-five">5</span>
      <small>CAFETARIA &amp; BROODJESBAR</small>
    </a>
    <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false">
      <span></span><span></span>
    </button>
    <nav class="main-nav" aria-label="Hoofdnavigatie">
      <a href="#menu">Menukaart</a>
      <a href="#over">Over Plein5</a>
      <a href="#bezoek">Bezoek ons</a>
      <a class="button button-small button-dark" href="tel:+31625055162">Bel voor afhalen</a>
    </nav>
  </header>

  <main id="main">
    <section class="hero">
      <img src="/assets/plein5-hero.jpg" alt="Verse friet en snacks bij Plein5" fetchpriority="high">
      <div class="hero-shade"></div>
      <div class="hero-content wrap">
        <p class="eyebrow light">Cafetaria &amp; broodjesbar · Beegden</p>
        <h1>Goed eten.<br><span>Gewoon op het plein.</span></h1>
        <p class="hero-copy">Vers, royaal en met plezier gemaakt. Bel je afhaalbestelling door of kom langs om bij ons te eten.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#menu">Bekijk menukaart</a>
          <a class="button button-ghost" href="tel:+31625055162">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6.6 10.8a15.4 15.4 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.2 1.2.4 2.5.7 3.8.7.6 0 1 .4 1 1v3.5c0 .6-.4 1-1 1A17.3 17.3 0 0 1 2.8 3.8c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.6.7 3.8.1.4 0 .8-.2 1.1l-2.2 2.1Z"/></svg>
            06 250 55 162
          </a>
        </div>
        <p class="service-note"><span></span> Telefonisch bestellen is voor afhalen · eten bij ons kan door langs te komen</p>
      </div>
    </section>

    <section class="quick-info reveal-on-scroll" aria-label="Praktische informatie">
      <div class="wrap quick-info-grid">
        <div>
          <span class="info-icon">↗</span>
          <p><strong>Vandaag geopend</strong><span id="today-hours">Bekijk openingstijden</span></p>
        </div>
        <div>
          <span class="info-icon">◎</span>
          <p><strong>Dorpsplein 5, Beegden</strong><span>Gratis parkeren voor de deur</span></p>
        </div>
        <div>
          <span class="info-icon">⌂</span>
          <p><strong>Afhalen of hier eten</strong><span>Telefonisch bestellen alleen voor afhalen</span></p>
        </div>
      </div>
    </section>

    <section class="section special-section" id="special-section">
      <div class="wrap special-card reveal-fly-in">
        <div class="special-media">
          <img id="special-image" src="/assets/plein5-hero.jpg" alt="" hidden>
          <div class="special-number" aria-hidden="true">05</div>
        </div>
        <div class="special-copy">
          <p class="eyebrow">Elke maand iets nieuws</p>
          <span class="special-label">Snack van de maand · <span id="special-month"></span></span>
          <h2 id="special-name">Pain American</h2>
          <p id="special-description"></p>
          <div class="special-bottom">
            <strong id="special-price"></strong>
            <span>Alleen deze maand verkrijgbaar</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section popular-section reveal-on-scroll" id="popular-section">
      <div class="wrap">
        <div class="section-heading compact-heading">
          <div>
            <p class="eyebrow">Vaak gekozen</p>
            <h2>Populair bij Plein5</h2>
          </div>
          <a class="text-link" href="#menu">Bekijk alles <span>→</span></a>
        </div>
        <div class="popular-grid" id="popular-grid" aria-live="polite"></div>
      </div>
    </section>

    <section class="section menu-section reveal-on-scroll" id="menu">
      <div class="wrap">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Kies waar je zin in hebt</p>
            <h2>Onze menukaart</h2>
          </div>
          <a class="phone-link" href="tel:+31625055162">Afhaalbestelling? <strong>Bel 06 250 55 162</strong></a>
        </div>
        <label class="menu-search">
          <span>Zoek in de menukaart</span>
          <input id="menu-search" type="search" placeholder="Zoek friet, saus, kroket..." autocomplete="off">
        </label>
        <div class="category-tabs" id="category-tabs" aria-label="Menucategorieën"></div>
        <div class="menu-grid" id="menu-grid" aria-live="polite">
          <p class="loading">Menukaart laden…</p>
        </div>
        <p class="menu-footnote">Prijzen en samenstelling kunnen wijzigen. <span id="menu-updated">Menukaart laden…</span></p>
      </div>
    </section>

    <section class="section story-section reveal-on-scroll" id="over">
      <div class="wrap story-grid">
        <div class="story-visual reveal-child">
          <div class="orange-panel"><span>PLEIN</span><strong>5</strong></div>
          <p>Van lunch tot avondeten,<br>zeven dagen per week.</p>
        </div>
        <div class="story-copy reveal-child">
          <p class="eyebrow">Welkom bij Plein5</p>
          <h2>Een fijne plek in het hart van Beegden.</h2>
          <p>Bij Plein5 draait het om lekker eten en een gastvrij welkom. Kom langs voor verse friet en snacks, een rijk belegd broodje, een milkshake of koffie met iets lekkers.</p>
          <p>Je vindt ons direct aan het dorpsplein, met gratis parkeergelegenheid voor de deur en een ruim terras uit de wind.</p>
          <a class="text-link" href="#bezoek">Plan je bezoek <span>→</span></a>
        </div>
      </div>
    </section>

    <section class="visit-section reveal-on-scroll" id="bezoek">
      <div class="wrap visit-grid">
        <div class="reveal-child">
          <p class="eyebrow light">Kom gezellig langs</p>
          <h2>Tot ziens<br>op het plein.</h2>
          <a class="button button-primary" href="https://www.google.com/maps/search/?api=1&query=Dorpsplein+5+6099+AS+Beegden" target="_blank" rel="noreferrer">Route naar Plein5</a>
        </div>
        <div class="contact-card reveal-child">
          <div class="contact-row">
            <span>Adres</span>
            <p>Dorpsplein 5<br>6099 AS Beegden</p>
          </div>
          <div class="contact-row">
            <span>Telefoon</span>
            <p><a href="tel:+31625055162">06 250 55 162</a></p>
          </div>
          <div class="contact-row hours-row">
            <span>Openingstijden</span>
            <dl>
              <div><dt>Ma — Vr</dt><dd>10:00 — 20:00</dd></div>
              <div><dt>Zaterdag</dt><dd>11:30 — 20:00</dd></div>
              <div><dt>Zondag</dt><dd>16:00 — 20:00</dd></div>
            </dl>
          </div>
          <p class="hours-note">Vanaf het paasweekend is Plein5 op zondag vanaf 11:30 geopend.</p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap footer-grid">
      <a class="brand footer-brand" href="#top"><span class="brand-word">PLEIN</span><span class="brand-five">5</span></a>
      <p>© <span id="year"></span> Plein5 Beegden</p>
      <a href="/admin">Beheer</a>
    </div>
  </footer>

  <nav class="mobile-actions" aria-label="Snelle acties">
    <a href="#menu">Menukaart</a>
    <a href="tel:+31625055162">Bel voor afhalen</a>
  </nav>

  <script is:inline src="/js/site.js?v=13" defer></script>
</body>
</html>
